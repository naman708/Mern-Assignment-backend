# Dependencies & build output (reinstalled/recompiled inside the image)
node_modules
dist

# Secrets & local env (never bake into the image)
.env
.env.*
!.env.example
!.env.docker.example

# Runtime data (mounted as a volume, not copied)
uploads

# VCS, logs, editor & OS noise
.git
.gitignore
*.log
npm-debug.log*
.vscode
.idea
.DS_Store
Thumbs.db

# Docker & docs not needed in the build context
Dockerfile
.dockerignore
docker-compose*.yml
README.md
requests.http
