# Environment for the Docker Compose stack.
# Copy to `.env.docker` and fill in real secrets:  cp .env.docker.example .env.docker
#
# NOTE: DB_HOST/DB_PORT/DB_NAME/DB_USER and REDIS_URL are set directly in
# docker-compose.yml (pointing at the `mysql` and `redis` services).

# ─── MySQL ────────────────────────────────────────────────────────────────────
# MYSQL_ROOT_PASSWORD configures the mysql container's root user.
# DB_PASSWORD is what the app sends to MySQL — keep the two values identical.
MYSQL_ROOT_PASSWORD=change_me_strong_password
DB_PASSWORD=change_me_strong_password

# ─── Public URLs ──────────────────────────────────────────────────────────────
APP_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
EMAIL_PROVIDER=ethereal
EMAIL_FROM=MERN Assignment <no-reply@example.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── Uploads ──────────────────────────────────────────────────────────────────
MAX_UPLOAD_BYTES=2097152
