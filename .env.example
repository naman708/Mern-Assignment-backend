# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Public URL of THIS backend (used to build email links & image URLs)
APP_URL=http://localhost:3000
# Frontend origin allowed by CORS (the React app, separate repo)
CLIENT_URL=http://localhost:5173

# ─── MySQL ───────────────────────────────────────────────────────────────────
# Either provide a full connection URL...
# DATABASE_URL=mysql://user:password@host:3306/dbname
# ...or the discrete vars below (used only when DATABASE_URL is empty):
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mern_assignment
DB_USER=root
DB_PASSWORD=
# Set true if your MySQL provider requires SSL (most managed/hosted ones do)
DB_SSL=false

# ─── Redis ───────────────────────────────────────────────────────────────────
# Full URL (e.g. from Render Key Value / Upstash). Falls back to localhost.
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Email (Nodemailer) ──────────────────────────────────────────────────────
# When EMAIL_PROVIDER=ethereal a throwaway test account is created automatically
# and message preview URLs are printed to the server logs (no real delivery).
EMAIL_PROVIDER=ethereal
EMAIL_FROM="MERN Assignment <no-reply@example.com>"
# Only needed when EMAIL_PROVIDER=smtp (e.g. Mailtrap / Gmail / SendGrid SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── Uploads ─────────────────────────────────────────────────────────────────
# Max profile image size in bytes (default 2MB)
MAX_UPLOAD_BYTES=2097152

# ─── Admin creation ──────────────────────────────────────────────────────────
# Shared secret the frontend must supply to POST /api/auth/create-admin to create
# an admin account. Leave empty to disable the endpoint.
ADMIN_CREATE_SECRET=change_me_admin_secret
